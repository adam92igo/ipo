# PostgreSQL connection string (dev default matches docker-compose.yml)
DATABASE_URL=postgresql://ipo:ipo_dev_password@localhost:5432/ipo_compass
# Separate database used by integration tests
TEST_DATABASE_URL=postgresql://ipo:ipo_dev_password@localhost:5432/ipo_compass_test
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# AI modules (module 5): profile pre-fill + IPO assistant.
# Without these keys the app runs fine — AI features show a setup notice.
# ANTHROPIC_API_KEY=
# PAPPERS_API_KEY=
# Optional model override (default: claude-sonnet-5)
# AI_MODEL=
# Per-organization AI rate limits (defaults shown below; sliding window).
# RATE_LIMIT_FILL_PROFILE_PER_HOUR=10
# RATE_LIMIT_ASSISTANT_MESSAGES_PER_DAY=100
# Demo environment (separate DB + port 3200) for investor/sales demos —
# see README, section "Demo environment". Each account owns exactly one
# company (the real product's tenancy model), so the demo uses 3 separate
# logins — one per readiness stage — rather than one account with 3 companies.
DEMO_DATABASE_URL=postgresql://ipo:ipo_dev_password@localhost:5432/ipo_compass_demo
DEMO_ACCOUNT_EMAIL_READY=
DEMO_ACCOUNT_EMAIL_MID=
DEMO_ACCOUNT_EMAIL_EARLY=
