# PostgreSQL connection string (dev default matches docker-compose.yml)
DATABASE_URL=postgresql://ipo:ipo_dev_password@localhost:5432/ipo_compass
# Separate database used by integration tests
TEST_DATABASE_URL=postgresql://ipo:ipo_dev_password@localhost:5432/ipo_compass_test
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# AI modules (module 5): profile pre-fill + IPO assistant.
# Without these keys the app runs fine — AI features show a setup notice.
# ANTHROPIC_API_KEY=
# PAPPERS_API_KEY=
# Optional model override (default: claude-sonnet-5)
# AI_MODEL=
